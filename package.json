{
  "name": "vscode-gemini-cli",
  "displayName": "Gemini CLI",
  "description": "VSCode extension for running Gemini CLI as an interactive terminal",
  "version": "0.2.0",
  "publisher": "gemini-cli",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "gemini",
    "ai",
    "cli",
    "terminal"
  ],
  "activationEvents": [
    "onView:geminiCliPanel",
    "onCommand:geminiCli.openPanel"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "geminiCli.openPanel",
        "title": "Open Gemini CLI",
        "icon": "media/terminal-icon.svg"
      }
    ],
    "views": {
      "geminiCli": [
        {
          "id": "geminiCliPanel",
          "name": "Terminal",
          "type": "webview",
          "icon": "media/terminal-icon.svg"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "geminiCli",
          "title": "Gemini CLI",
          "icon": "media/terminal-icon.svg"
        }
      ]
    },
    "configuration": {
      "title": "Gemini CLI",
      "properties": {
        "geminiCli.executablePath": {
          "type": "string",
          "default": "gemini",
          "description": "Path to Gemini CLI executable"
        }
      }
    },
    "keybindings": [
      {
        "command": "geminiCli.openPanel",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/node": "16.x",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "@vscode/vsce": "^2.15.0",
    "eslint": "^8.28.0",
    "typescript": "^4.9.4"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "node-pty": "^1.1.0",
    "xterm": "^5.3.0"
  }
}
